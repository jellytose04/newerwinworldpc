<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Floppy Transfer Tool</title>
    <style>
        body { font-family: sans-serif; display: flex; flex-direction: column; align-items: center; padding: 50px; }
        button { padding: 15px 30px; font-size: 1.2rem; cursor: pointer; background: #007bff; color: white; border: none; border-radius: 5px; }
        #status { margin-top: 20px; color: #555; }
    </style>
</head>
<body>

    <button id="transferBtn">Transfer Floppy</button>
    <div id="status">Ready. (Note: You must select the destination folder first)</div>

    <script>
        let transferCount = 0;
        const btn = document.getElementById('transferBtn');
        const status = document.getElementById('status');

        btn.addEventListener('click', async () => {
            try {
                // 1. Ask user to pick a base directory to save into
                status.innerText = "Select the folder where 'floppy' directories should be created...";
                const baseDirHandle = await window.showDirectoryPicker();

                // 2. Ask user to select files from the Floppy (A: or B:)
                status.innerText = "Please browse to A:\\ or B:\\ and select files...";
                const fileHandles = await window.showOpenFilePicker({ multiple: true });

                // 3. Create the new sub-folder: floppy[number]
                transferCount++;
                const newFolderName = `floppy${transferCount}`;
                const newFolderHandle = await baseDirHandle.getDirectoryHandle(newFolderName, { create: true });

                // 4. "Transfer" (Copy) each file
                for (const fileHandle of fileHandles) {
                    const file = await fileHandle.getFile();
                    const newFileHandle = await newFolderHandle.getFileHandle(file.name, { create: true });
                    const writable = await newFileHandle.createWritable();
                    await writable.write(file);
                    await writable.close();
                }

                status.innerText = `Success! Transferred ${fileHandles.length} files to ${newFolderName}.`;
            } catch (err) {
                console.error(err);
                status.innerText = "Transfer cancelled or failed. (Browsers cannot force Drive A: access).";
            }
        });
    </script>
</body>
</html>
